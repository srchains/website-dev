# Resend Email Configuration
# Sign up at https://resend.com and get your API key from the dashboard.

# Your Resend API key
RESEND_API_KEY=your_resend_api_key_here

# Email address to receive contact form submissions
EMAIL_TO=your@email.com

# Sender — use onboarding@resend.dev for testing (no domain needed)
# After verifying your domain on resend.com, change to: YourName <hello@yourdomain.com>
EMAIL_FROM=BuildStack Solutions <onboarding@resend.dev>
